generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MENTORADO
}

enum SiteStatus {
  DRAFT
  GENERATING
  PREVIEW
  PUBLISHED
  ERROR
}


model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role     @default(MENTORADO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites     Site[]
  carrosseis Carrossel[]

  @@map("users")
}

model Site {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identidade
  nomeNegocio String
  segmento    String
  cidade      String
  estado      String
  endereco    String
  cep         String
  corPaleta   String
  logoUrl     String?

  // Serviços
  servicos         Servico[]
  servicoDestaque  String
  resultadoCliente String

  // Público
  dorPrincipal String

  // Hero
  heroFotoUrl String?
  headline    String?
  subheadline String?
  ctaTexto    String?

  // Credibilidade
  anosNoMercado       Int
  totalClientes       Int?
  totalClientesLabel  String?
  certificados        String?
  depoimentos    Depoimento[]

  // Fotos
  foto1Url            String?
  foto2Url            String?
  foto3Url            String?
  fotoProfissionalUrl String?

  // Contato
  whatsapp              String
  whatsappMensagem      String
  instagram             String?
  horarioAtendimento    String
  registros             RegistroProfissional[]

  // Rastreamento
  metaPixelId    String?
  metaPixelToken String?
  gtmId          String?

  // Site gerado
  slug            String?    @unique
  subdomain       String?    @unique
  htmlGerado      String?    @db.Text
  vercelProjectId String?
  vercelUrl       String?
  status          SiteStatus @default(DRAFT)
  geracoesCount   Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sites")
}

model Carrossel {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Configuração usada na geração
  titulo String
  nicho  String
  tipo   String // id da narrativa: origem, caso_sucesso, educativo...
  tom    String // id do tom: narrativo, direto, emocional...
  tema   String @db.Text
  estilo String // tema visual: thread | viral

  // Perfil exibido nos slides
  nome       String?
  instagram  String?
  fotoPerfil String? @db.Text // data URL ou URL

  // Conteúdo completo (slides, legenda, hashtags) como JSON
  conteudo Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("carrosseis")
}

model Servico {
  id        String  @id @default(uuid())
  siteId    String
  site      Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  nome      String
  descricao String?
  ordem     Int     @default(0)

  @@map("servicos")
}

model Depoimento {
  id        String @id @default(uuid())
  siteId    String
  site      Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  imagemUrl String

  @@map("depoimentos")
}

model RegistroProfissional {
  id     String @id @default(uuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  tipo   String
  numero String

  @@map("registros_profissionais")
}
