generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MENTORADO
}

enum SiteStatus {
  DRAFT
  GENERATING
  PREVIEW
  PUBLISHED
  ERROR
}


model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role     @default(MENTORADO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites     Site[]

  @@map("users")
}

model Site {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identidade
  nomeNegocio String
  segmento    String
  cidade      String
  estado      String
  endereco    String
  cep         String
  corPaleta   String
  logoUrl     String?

  // Serviços
  servicos         Servico[]
  servicoDestaque  String
  resultadoCliente String

  // Público
  dorPrincipal String

  // Hero
  heroFotoUrl String?
  headline    String?
  subheadline String?
  ctaTexto    String?

  // Credibilidade
  anosNoMercado  Int
  totalClientes  Int?
  certificados   String?
  depoimentos    Depoimento[]

  // Fotos
  foto1Url            String?
  foto2Url            String?
  foto3Url            String?
  fotoProfissionalUrl String?

  // Contato
  whatsapp           String
  whatsappMensagem   String
  instagram          String?
  horarioAtendimento String

  // Rastreamento
  metaPixelId    String?
  metaPixelToken String?
  gtmId          String?

  // Site gerado
  slug            String?    @unique
  subdomain       String?    @unique
  htmlGerado      String?    @db.Text
  vercelProjectId String?
  vercelUrl       String?
  status          SiteStatus @default(DRAFT)
  geracoesCount   Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sites")
}

model Servico {
  id        String  @id @default(uuid())
  siteId    String
  site      Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  nome      String
  descricao String?
  ordem     Int     @default(0)

  @@map("servicos")
}

model Depoimento {
  id        String @id @default(uuid())
  siteId    String
  site      Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  imagemUrl String

  @@map("depoimentos")
}
